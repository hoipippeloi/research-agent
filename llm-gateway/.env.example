# Qwen3.5-4B LLM Gateway Environment Variables

# Server Configuration
HOST=0.0.0.0
PORT=8080

# Model Configuration
MODEL_NAME=qwen3.5-4b
MODEL_PATH=/models/qwen3.5-4b-instruct-q4_K_M.gguf
CONTEXT_SIZE=262000

# GPU Configuration (local development)
# Number of GPU layers to offload (99 = all layers for local GPU, 0 = CPU-only for Railway)
GPU_LAYERS=99

# Railway-specific settings (auto-configured in production)
RAILWAY_ENVIRONMENT=development

# Optional: API Key for authentication (set in Railway dashboard)
# API_KEY=your-secret-key-here

# Performance tuning
THREADS=4
BATCH_SIZE=512

# Model download settings (for initial setup)
HUGGINGFACE_REPO=Qwen/Qwen3.5-4B-Instruct-GGUF
HUGGINGFACE_FILE=qwen3.5-4b-instruct-q4_K_M.gguf
