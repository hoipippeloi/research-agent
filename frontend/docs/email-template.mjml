<mjml>
  <mj-head>
    <mj-attributes>
      <mj-text font-family="Inter, -apple-system, BlinkMacSystemFont, sans-serif" font-size="14px" line-height="1.6" color="#71717a"/>
      <mj-button font-family="Inter, -apple-system, BlinkMacSystemFont, sans-serif" background-color="#18181b" border-radius="8px" font-weight="500" font-size="13px" padding="12px 24px"/>
    </mj-attributes>
  </mj-head>
  <mj-body background-color="#fafafa">
    <!-- Header -->
    <mj-section padding="40px 20px 20px">
      <mj-column width="100%">
        <mj-text align="center" padding="0">
          <div style="display:inline-block;width:36px;height:36px;background:#18181b;border-radius:10px;line-height:36px;">
            <img src="https://hoi-email.up.railway.app/favicon.ico" width="20" height="20" style="vertical-align:middle;border-radius:2px"/>
          </div>
        </mj-text>
        <mj-text align="center" font-size="11px" font-weight="500" color="#a1a1aa" padding-top="12px" letter-spacing="0.1em" text-transform="uppercase">
          Research Agent
        </mj-text>
      </mj-column>
    </mj-section>
    
    <!-- Main Card -->
    <mj-section padding="0 20px 40px">
      <mj-column background-color="#ffffff" border-radius="16px" padding="24px" border="1px solid rgba(228, 228, 231, 0.7)">
        <mj-text padding-bottom="0">
          <p style="margin:0 0 4px;font-size:11px;color:#a1a1aa;text-transform:uppercase;letter-spacing:0.05em;">New Signup</p>
        </mj-text>
        <mj-text font-size="20px" font-weight="600" color="#18181b" padding-top="4px" padding-bottom="16px" letter-spacing="-0.01em">
          <p style="margin:0;">A new user has signed up</p>
        </mj-text>
        
        <!-- Email Box -->
        <mj-text padding="16px" background-color="#fafafa" border-radius="12px" border="1px solid rgba(228, 228, 231, 0.5)">
          <p style="margin:0 0 8px;font-size:11px;color:#a1a1aa;text-transform:uppercase;letter-spacing:0.05em;">Email Address</p>
          <p style="margin:0;font-size:16px;font-weight:500;color:#18181b;font-family:'Space Mono', 'PT Mono', 'Courier New', monospace;">{{new_user_email}}</p>
        </mj-text>
        
        <!-- Timestamp -->
        <mj-text padding-top="16px" padding-bottom="24px">
          <p style="margin:0;font-size:13px;color:#71717a;">📅 {{timestamp}}</p>
        </mj-text>
        
        <!-- CTA Button -->
        <mj-button href="mailto:{{new_user_email}}">Contact User</mj-button>
      </mj-column>
    </mj-section>
    
    <!-- Footer -->
    <mj-section padding="0 20px 40px">
      <mj-column>
        <mj-text align="center" font-size="12px" color="#a1a1aa">
          <p style="margin:0;">Built with care by <a href="https://hoi-research.up.railway.app" style="color:#18181b;text-decoration:none;font-weight:500;">Research Agent</a></p>
          <p style="margin:4px 0 0;font-size:11px;">Privacy-First Search</p>
        </mj-text>
      </mj-column>
    </mj-section>
  </mj-body>
</mjml>
