<!-- UserRegistration.mjml - New User Registration Notification -->
<!-- This content is injected into {{Content}} in _Layout.mjml -->

<mj-text font-size="24px" font-weight="700" color="#18181b" letter-spacing="-0.01em" line-height="1.5" padding-bottom="8px" align="center">
  New User Signup
</mj-text>

<mj-text font-size="14px" color="#71717a" padding-bottom="24px" align="center">
  Archive
</mj-text>

<mj-text font-size="14px" color="#71717a" padding-bottom="16px">
  A new user has signed up for Archive:
</mj-text>

<!-- User Information Card with Gradient Background -->
<mj-text padding="0 0 24px 0">
  <table role="presentation" cellpadding="0" cellspacing="0" width="100%">
    <tr>
      <td style="background: linear-gradient(135deg, #fafafa 0%, #f4f1f0 25%, #f0f4f8 50%, #fdf4f4 75%, #fafafa 100%); border-radius: 12px; padding: 20px;">
        <table role="presentation" cellpadding="0" cellspacing="0" width="100%">
          <tr>
            <td style="padding-bottom: 8px;">
              <p style="margin: 0; font-size: 12px; color: #71717a; text-transform: uppercase; letter-spacing: 0.05em; font-family: 'Inter', -apple-system, sans-serif;">
                Email Address
              </p>
            </td>
          </tr>
          <tr>
            <td style="padding-bottom: 20px;">
              <p style="margin: 0; font-size: 18px; font-weight: 600; color: #18181b; font-family: 'Space Mono', 'Courier New', monospace;">
                {{EmailAddress}}
              </p>
            </td>
          </tr>
          <tr>
            <td>
              <p style="margin: 0; font-size: 13px; color: #71717a; font-family: 'Inter', -apple-system, sans-serif;">
                📅 <span style="font-family: 'Space Mono', 'Courier New', monospace;">{{SignupDate}}</span>
              </p>
            </td>
          </tr>
        </table>
      </td>
    </tr>
  </table>
</mj-text>

<!-- Action Button -->
<mj-button
  background-color="#18181b"
  color="#ffffff"
  font-size="14px"
  font-weight="600"
  border-radius="3px"
  inner-padding="10px 25px"
  href="mailto:{{EmailAddress}}"
>
  Contact User
</mj-button>
