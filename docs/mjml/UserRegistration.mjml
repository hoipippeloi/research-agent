<!-- UserRegistration.mjml - New User Registration Notification -->
<!-- This content is injected into {{Content}} in _Layout.mjml -->

<mj-raw>
  <!-- Header Section -->
</mj-raw>
<mj-section background-color="#fafafa" padding="20px 0">
  <mj-column>
    <mj-text
      font-size="24px"
      font-weight="700"
      color="#18181b"
      letter-spacing="-0.01em"
      line-height="1.5"
      padding-bottom="8px"
      align="center"
      font-family="Inter, -apple-system, sans-serif">
      New User Signup
    </mj-text>

    <mj-text
      font-size="14px"
      color="#71717a"
      align="center"
      font-family="Inter, -apple-system, sans-serif">
      Archive
    </mj-text>
  </mj-column>
</mj-section>

<mj-raw>
  <!-- Introduction Text -->
</mj-raw>
<mj-section background-color="#ffffff" padding="0 20px">
  <mj-column>
    <mj-text
      font-size="14px"
      color="#71717a"
      padding-bottom="16px"
      font-family="Inter, -apple-system, sans-serif">
      A new user has signed up for Archive:
    </mj-text>
  </mj-column>
</mj-section>

<mj-raw>
  <!-- User Information Card -->
</mj-raw>
<mj-section background-color="#ffffff" padding="0 20px 24px 20px">
  <mj-column
    background-color="#f0f4f8"
    border="1px solid #e4e4e7"
    border-radius="12px"
    padding="20px">

    <mj-text
      font-size="12px"
      color="#71717a"
      text-transform="uppercase"
      letter-spacing="0.05em"
      padding-bottom="8px"
      font-family="Inter, -apple-system, sans-serif">
      Email Address
    </mj-text>

    <mj-text
      font-size="18px"
      font-weight="600"
      color="#18181b"
      padding-bottom="20px"
      font-family="Space Mono, Courier New, monospace">
      {{EmailAddress}}
    </mj-text>

    <mj-text
      font-size="13px"
      color="#71717a"
      font-family="Inter, -apple-system, sans-serif">
      📅 <span style="font-family: 'Space Mono', 'Courier New', monospace;">{{SignupDate}}</span>
    </mj-text>

  </mj-column>
</mj-section>

<mj-raw>
  <!-- Action Button -->
</mj-raw>
<mj-section background-color="#ffffff" padding="0 20px 20px 20px">
  <mj-column>
    <mj-button
      background-color="#18181b"
      color="#ffffff"
      font-size="14px"
      font-weight="600"
      border-radius="3px"
      inner-padding="10px 25px"
      href="mailto:{{EmailAddress}}"
      font-family="Inter, -apple-system, sans-serif">
      Contact User
    </mj-button>
  </mj-column>
</mj-section>
